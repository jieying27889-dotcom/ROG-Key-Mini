<Window
    x:Class="RogKeyMini.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RogKeyMini"
    Width="510"
    Height="120"
    WindowStyle="None"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="Transparent"
    ShowActivated="False"
    ShowInTaskbar="False"
    Topmost="True">
    <Window.Resources>
        <!-- Pure Vector Carbon Fiber Brush -->
        <DrawingBrush x:Key="CarbonFiberBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#121214">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#1A1A1E">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 0,0 L 4,4 L 4,8 L 0,4 Z M 4,0 L 8,4 L 8,8 L 4,4 Z" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#222228">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 4,0 L 8,0 L 4,4 Z M 0,4 L 4,4 L 0,8 Z" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Custom Button Style -->
        <Style x:Key="RogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#222226" />
            <Setter Property="Foreground" Value="#FFFF2E50" />
            <Setter Property="BorderBrush" Value="#44FF2E50" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect x:Name="Glow" Color="#FF0033" BlurRadius="6" ShadowDepth="0" Opacity="0.15" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#32323A" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFFF2E50" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#18181A" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFCC0022" />
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Outer Container with Glow and Rounded Corners -->
    <Border Width="480" 
            Height="90" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            BorderThickness="1.5" 
            CornerRadius="12" 
            Background="{StaticResource CarbonFiberBrush}">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFF2E50" Offset="0" />
                <GradientStop Color="#FF8000FF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#FF0033" BlurRadius="16" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Title Bar -->
            <TextBlock Grid.Row="0" 
                       Text="RogKeyMini" 
                       FontSize="9" 
                       Foreground="#FFAAAAAA" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Margin="0,3,0,0"
                       Opacity="0.8"
                       IsHitTestVisible="False">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.5" />
                </TextBlock.Effect>
            </TextBlock>

            <!-- Bottom Button & Logo area -->
            <Grid Grid.Row="1" Margin="8,0,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ROG Eye Logo (Left) -->
                <Path Grid.Column="0" 
                      Width="28" 
                      Height="28" 
                      Stretch="Uniform" 
                      Fill="#FFFF2E50" 
                      Margin="8,0,8,0" 
                      VerticalAlignment="Center"
                      Data="F1 M 33.1,10.1 C 32.7,9.9 27.2,8.0 21.8,10.0 C 21.5,10.1 21.2,10.2 21.0,10.4 C 20.3,11.0 19.3,12.4 18.4,14.7 C 18.0,15.5 17.6,16.4 17.3,17.3 C 16.7,19.2 16.3,21.0 16.2,22.6 C 16.1,23.8 16.3,24.8 16.7,25.5 C 16.9,25.9 17.3,26.2 17.8,26.3 C 17.9,26.3 18.1,26.3 18.3,26.3 C 20.0,26.3 22.2,24.4 24.1,21.6 C 25.4,19.8 26.5,17.6 27.4,15.2 C 28.1,13.5 31.2,10.7 33.1,10.1 Z M 10.6,19.5 C 10.9,18.6 11.4,17.3 12.3,15.7 C 13.3,13.8 14.7,11.9 16.4,10.1 C 18.0,8.4 19.9,6.8 22.0,5.5 C 23.7,4.4 25.5,3.5 27.3,2.9 C 27.7,2.8 28.2,2.7 28.6,2.7 C 28.9,2.7 29.2,2.8 29.3,3.0 C 29.4,3.2 29.4,3.5 29.2,3.7 C 27.6,5.1 23.9,9.1 21.8,14.1 C 21.3,15.3 20.9,16.6 20.6,18.0 C 20.3,19.3 20.2,20.7 20.2,22.0 C 20.2,23.0 20.0,23.8 19.6,24.4 C 19.3,24.8 18.9,25.0 18.4,25.1 C 18.3,25.1 18.1,25.1 18.0,25.1 C 16.9,25.1 15.4,23.7 14.0,21.8 C 12.9,20.2 11.7,19.8 10.6,19.5 Z M 30.2,0 L 24.5,5.7 L 33.0,3.8 Z">
                    <Path.Effect>
                        <DropShadowEffect Color="#FF0033" BlurRadius="6" ShadowDepth="0" Opacity="0.4" />
                    </Path.Effect>
                </Path>

                <!-- Horizontal Button Row (Right) -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,4,0">
                    
                    <Button Style="{StaticResource RogButtonStyle}" Content="F2" Click="F2Button_OnClick" />
                    <Button Style="{StaticResource RogButtonStyle}" Content="F7" Click="F7Button_OnClick" />
                    <Button Style="{StaticResource RogButtonStyle}" Content="-" Click="MinusButton_OnClick" />
                    <Button Style="{StaticResource RogButtonStyle}" Content="_" Click="UnderscoreButton_OnClick" />
                    
                    <!-- Keyboard backlight down button -->
                    <Button Style="{StaticResource RogButtonStyle}" Click="KeyboardBacklightButton_OnClick">
                        <Path Width="18" Height="18" Stretch="Uniform" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                              Data="M2,5 C1.4,5 1,5.4 1,6 L1,14 C1,14.6 1.4,15 2,15 L18,15 C18.6,15 19,14.6 19,14 L19,6 C19,5.4 18.6,5 18,5 Z M3,7 H5 V8 H3 Z M7,7 H9 V8 H7 Z M11,7 H13 V8 H11 Z M15,7 H17 V8 H15 Z M3,10 H5 V11 H3 Z M7,10 H13 V11 H7 Z M15,10 H17 V11 H15 Z M2,13 H18 V14 H2 Z" />
                    </Button>
                    
                    <!-- Screen brightness down button -->
                    <Button Style="{StaticResource RogButtonStyle}" Margin="0,0,8,0" Click="ScreenBrightnessButton_OnClick">
                        <Path Width="18" Height="18" Stretch="Uniform" 
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                              Data="M10,5 C7.2,5 5,7.2 5,10 C5,12.8 7.2,15 10,15 C12.8,15 15,12.8 15,10 C15,7.2 12.8,5 10,5 Z M10,1 V3 M10,17 V19 M1,10 H3 M17,10 H19 M3.6,3.6 L5,5 M15,15 L16.4,16.4 M3.6,16.4 L5,15 M15,3.6 L16.4,5 M14,16 H18 V17 H14 Z" />
                    </Button>
                    
                    <!-- OSK screen keyboard button -->
                    <Button Style="{StaticResource RogButtonStyle}" Margin="0,0,8,0" Content="OSK" Click="OskButton_OnClick" />
                    
                    <!-- Auto release toggle button -->
                    <Button x:Name="AutoReleaseBtn" Style="{StaticResource RogButtonStyle}" Margin="0" Content="自释" Click="AutoReleaseButton_OnClick" />
                    
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
